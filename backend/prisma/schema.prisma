// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int    @id @default(autoincrement())
  title       String
  description String
}

model GenerationHistory {
  id            Int      @id @default(autoincrement())
  productName   String
  generatedText String
  tone          String
  createdAt     DateTime @default(now())
}



model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // this will store the bcrypt HASH, never plain text
  createdAt DateTime @default(now())
}